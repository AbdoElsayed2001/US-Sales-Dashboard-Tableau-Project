      <aliases enabled='yes' />
      <column datatype='integer' name='[Age]' role='measure' type='quantitative' />
      <column caption='Named Gender' datatype='string' name='[Calculation_0492909707702272]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Gender] = &apos;M&apos; THEN &apos;Male&apos;&#13;&#10;ELSEIF [Gender] = &apos;F&apos; THEN &apos;Female&apos;&#13;&#10;END' />
      </column>
      <column caption='Named State' datatype='string' name='[Calculation_0492909709844481]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [State]&#13;&#10;WHEN &apos;CA&apos; THEN &apos;California&apos;&#13;&#10;WHEN &apos;CO&apos; Then &apos;Colorado&apos;&#13;&#10;WHEN &apos;FL&apos; Then &apos;Florida&apos;&#13;&#10;WHEN &apos;IL&apos; Then &apos;Illinois&apos;&#13;&#10;WHEN &apos;MI&apos; Then &apos;Michigan&apos;&#13;&#10;WHEN &apos;NY&apos; Then &apos;New York&apos;&#13;&#10;WHEN &apos;OR&apos; Then &apos;Oregon&apos;&#13;&#10;WHEN &apos;TX&apos; Then &apos;Texas&apos;&#13;&#10;WHEN &apos;WA&apos; Then &apos;Washington&apos;&#13;&#10;END' />
      </column>
      <column caption='UbberCategory' datatype='string' name='[Calculation_0492909714419714]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='UPPER([Category])' />
      </column>
      <column caption='Year' datatype='integer' name='[Calculation_0492909719654403]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([Date])' />
      </column>
      <column caption='rank' datatype='integer' name='[Calculation_0492909724221444]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(COUNT([__tableau_internal_object_id__].[Final Product &amp; Sales Data_D2F42CCA17434FDCBE4CA8A7C39272EA]),&apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sales per state' datatype='integer' name='[Calculation_0492909727223813]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [State] : COUNT([__tableau_internal_object_id__].[Final Product &amp; Sales Data_D2F42CCA17434FDCBE4CA8A7C39272EA])}' />
      </column>
      <column caption='Profit' datatype='real' name='[Calculation_0492909877800966]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Price]-[Cost_Price]' />
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_0492909878558727]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0492909877800966]/[Quantity]' />
      </column>
      <column caption='Final Price' datatype='real' name='[Calculation_0517373513994240]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Cost_Price]-[Discount]' />
      </column>
      <column caption='Show Map' datatype='boolean' name='[Calculation_0862896626442240]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 2]= &quot;Yes&quot;' />
      </column>
      <column caption='Product Category Expand' datatype='string' name='[Calculation_0862896797892609]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Product Category Set] THEN [Product_Name]&#13;&#10;ELSE &apos;&apos;&#13;&#10;END' />
